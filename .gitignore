```gitignore
# =========================
# Python
# =========================

__pycache__/
*.py[cod]
*$py.class

# Compiled extensions
*.so

# Distribution / packaging
build/
dist/
downloads/
.eggs/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =========================
# Virtual Environments
# =========================

venv/
.venv/
env/
ENV/

# =========================
# Jupyter
# =========================

.ipynb_checkpoints/

# =========================
# VS Code
# =========================

.vscode/

# =========================
# PyCharm
# =========================

.idea/

# =========================
# Logs
# =========================

*.log

# =========================
# Environment Variables
# =========================

.env
.env.*

# =========================
# Dataset Storage
# =========================

datasets/
data/

# =========================
# Model Checkpoints
# =========================

checkpoints/
models/

*.pth
*.pt
*.ckpt
*.h5
*.onnx
*.pb

# =========================
# Experiment Outputs
# =========================

runs/
wandb/
mlruns/
lightning_logs/
tensorboard/

# =========================
# Temporary Files
# =========================

tmp/
temp/

# =========================
# OS Files
# =========================

.DS_Store
Thumbs.db

# =========================
# Cache
# =========================

.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# =========================
# Google Colab
# =========================

.content/

# =========================
# Large Archives
# =========================

*.zip
*.tar
*.tar.gz
*.7z

# =========================
# Keep Folder Structure
# =========================

!datasets/.gitkeep
!checkpoints/.gitkeep
```
